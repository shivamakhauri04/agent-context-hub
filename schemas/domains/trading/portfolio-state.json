{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portfolio State",
  "description": "Schema representing the current state of a trading portfolio.",
  "type": "object",
  "required": ["account_type", "equity", "cash", "day_trades_count_5d"],
  "properties": {
    "account_type": {
      "type": "string",
      "enum": ["cash", "margin", "futures"],
      "description": "Type of brokerage account."
    },
    "equity": {
      "type": "number",
      "description": "Total account equity."
    },
    "cash": {
      "type": "number",
      "description": "Available cash balance."
    },
    "positions": {
      "type": "array",
      "description": "Current open positions.",
      "items": {
        "type": "object",
        "required": ["symbol", "quantity", "avg_cost", "current_price", "unrealized_pnl"],
        "properties": {
          "symbol": {"type": "string"},
          "quantity": {"type": "number"},
          "avg_cost": {"type": "number"},
          "current_price": {"type": "number"},
          "unrealized_pnl": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "recent_trades": {
      "type": "array",
      "description": "Recent completed trades.",
      "items": {
        "type": "object",
        "required": ["symbol", "action", "quantity", "price", "date", "pnl"],
        "properties": {
          "symbol": {"type": "string"},
          "action": {"type": "string"},
          "quantity": {"type": "number"},
          "price": {"type": "number"},
          "date": {"type": "string", "format": "date"},
          "pnl": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "day_trades_count_5d": {
      "type": "integer",
      "description": "Number of day trades in the last 5 trading days."
    },
    "ira_type": {
      "type": "string",
      "enum": ["traditional", "roth"],
      "description": "IRA account type, if applicable."
    },
    "ira_contribution_ytd": {
      "type": "number",
      "description": "Year-to-date IRA contributions across all IRAs."
    },
    "account_holder_age": {
      "type": "number",
      "description": "Account holder age (for IRA contribution/withdrawal rules)."
    },
    "magi": {
      "type": "number",
      "description": "Modified Adjusted Gross Income (for Roth IRA eligibility)."
    },
    "filing_status": {
      "type": "string",
      "enum": ["single", "married_filing_jointly", "married_filing_separately"],
      "description": "Tax filing status (for Roth MAGI phase-out thresholds)."
    },
    "withdrawal_amount": {
      "type": "number",
      "description": "Pending withdrawal amount (for early withdrawal penalty check)."
    },
    "asset_class": {
      "type": "string",
      "enum": ["equity", "crypto", "futures", "options", "event_contract"],
      "description": "Primary asset class for the account or trade."
    },
    "futures_positions": {
      "type": "array",
      "description": "Current futures contract positions.",
      "items": {
        "type": "object",
        "required": ["symbol", "contracts"],
        "properties": {
          "symbol": {"type": "string"},
          "contracts": {"type": "integer"},
          "avg_entry_price": {"type": "number"},
          "current_price": {"type": "number"},
          "unrealized_pnl": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "futures_account_balance": {
      "type": "number",
      "description": "Cash balance in the futures account for margin requirements."
    },
    "futures_day_trade": {
      "type": "boolean",
      "description": "Whether current futures positions are day trades (50% initial margin)."
    },
    "settlement_days": {
      "type": "integer",
      "description": "Settlement cycle in business days (1 for US equities since May 2024)."
    },
    "gfv_count_12m": {
      "type": "integer",
      "description": "Good Faith Violations in the last 12 months (cash accounts)."
    },
    "unsettled_cash": {
      "type": "number",
      "description": "Cash from recent sales that has not yet settled."
    },
    "pending_buy_with_unsettled": {
      "type": "boolean",
      "description": "Whether a pending buy order uses unsettled funds."
    },
    "short_positions": {
      "type": "array",
      "description": "Current short positions.",
      "items": {
        "type": "object",
        "required": ["symbol", "quantity"],
        "properties": {
          "symbol": {"type": "string"},
          "quantity": {"type": "number"},
          "locate_obtained": {"type": "boolean"},
          "is_hard_to_borrow": {"type": "boolean"},
          "borrow_rate_annualized": {"type": "number"},
          "days_short": {"type": "integer"},
          "is_threshold_security": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "short_margin_equity": {
      "type": "number",
      "description": "Equity allocated to short positions."
    },
    "short_market_value": {
      "type": "number",
      "description": "Total market value of short positions."
    },
    "threshold_securities": {
      "type": "array",
      "description": "Symbols on the Reg SHO threshold securities list.",
      "items": {"type": "string"}
    },
    "target_allocations": {
      "type": "array",
      "description": "Target portfolio allocation percentages.",
      "items": {
        "type": "object",
        "required": ["asset_class", "target_pct"],
        "properties": {
          "asset_class": {"type": "string"},
          "target_pct": {"type": "number"},
          "current_pct": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "rebalance_threshold_pct": {
      "type": "number",
      "description": "Maximum allowed drift percentage before rebalancing triggers."
    },
    "rebalance_min_trade_usd": {
      "type": "number",
      "description": "Minimum trade size in USD for rebalancing (avoids micro-trades)."
    },
    "zero_dte_positions": {
      "type": "array",
      "description": "Current 0DTE (same-day expiration) options positions.",
      "items": {
        "type": "object",
        "required": ["symbol", "direction"],
        "properties": {
          "symbol": {"type": "string"},
          "direction": {"type": "string", "enum": ["long", "short"]},
          "max_loss": {"type": "number"},
          "exercise_cost": {"type": "number"},
          "contracts": {"type": "integer"}
        },
        "additionalProperties": false
      }
    },
    "zero_dte_max_portfolio_pct": {
      "type": "number",
      "description": "Maximum portfolio percentage allowed for 0DTE positions."
    },
    "recurring_investments": {
      "type": "array",
      "description": "Configured recurring investment schedules.",
      "items": {
        "type": "object",
        "required": ["symbol", "amount_usd", "frequency"],
        "properties": {
          "symbol": {"type": "string"},
          "amount_usd": {"type": "number"},
          "frequency": {
            "type": "string",
            "enum": ["daily", "weekly", "biweekly", "monthly"]
          }
        },
        "additionalProperties": false
      }
    },
    "recurring_total_monthly_usd": {
      "type": "number",
      "description": "Total estimated monthly recurring investment amount."
    },
    "options_approval_level": {
      "type": "integer",
      "description": "Options trading approval level (0-5)."
    },
    "pending_options_strategies": {
      "type": "array",
      "description": "Pending options strategies awaiting execution.",
      "items": {
        "type": "object",
        "required": ["strategy", "symbol"],
        "properties": {
          "strategy": {"type": "string"},
          "symbol": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "expiring_options": {
      "type": "array",
      "description": "Options nearing expiration.",
      "items": {
        "type": "object",
        "required": ["symbol", "exercise_cost"],
        "properties": {
          "symbol": {"type": "string"},
          "exercise_cost": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "market_value": {
      "type": "number",
      "description": "Total market value of all positions."
    },
    "house_margin_requirement": {
      "type": "number",
      "description": "Broker house margin maintenance requirement (e.g. 0.30 for 30%)."
    },
    "spouse_trades": {
      "type": "array",
      "description": "Recent trades in spouse accounts (for wash sale cross-account check).",
      "items": {
        "type": "object",
        "properties": {
          "symbol": {"type": "string"},
          "action": {"type": "string"},
          "quantity": {"type": "number"},
          "price": {"type": "number"},
          "date": {"type": "string", "format": "date"},
          "pnl": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "other_accounts": {
      "type": "array",
      "description": "Recent trades in other owned accounts (for wash sale cross-account check).",
      "items": {
        "type": "object",
        "properties": {
          "symbol": {"type": "string"},
          "action": {"type": "string"},
          "quantity": {"type": "number"},
          "price": {"type": "number"},
          "date": {"type": "string", "format": "date"},
          "pnl": {"type": "number"}
        },
        "additionalProperties": false
      }
    },
    "harvest_opportunities": {
      "type": "array",
      "description": "Tax-loss harvesting opportunities identified in the portfolio.",
      "items": {
        "type": "object",
        "required": ["symbol", "unrealized_loss"],
        "properties": {
          "symbol": {"type": "string"},
          "unrealized_loss": {"type": "number"},
          "holding_days": {"type": "integer"},
          "proposed_replacement": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "capital_gains_ytd": {
      "type": "number",
      "description": "Year-to-date realized capital gains."
    },
    "capital_losses_ytd": {
      "type": "number",
      "description": "Year-to-date realized capital losses (positive number)."
    },
    "loss_carryforward": {
      "type": "number",
      "description": "Capital loss carryforward from prior tax years."
    },
    "ira_recent_purchases": {
      "type": "array",
      "description": "Recent purchases in IRA accounts (for cross-account wash sale check).",
      "items": {
        "type": "object",
        "required": ["symbol", "date"],
        "properties": {
          "symbol": {"type": "string"},
          "date": {"type": "string", "format": "date"}
        },
        "additionalProperties": false
      }
    },
    "goal_type": {
      "type": "string",
      "enum": [
        "retirement",
        "emergency_fund",
        "house_down_payment",
        "education",
        "general_investing"
      ],
      "description": "Investment goal type for goal-based allocation."
    },
    "goal_time_horizon_years": {
      "type": "number",
      "description": "Years until goal target date."
    },
    "goal_target_amount": {
      "type": "number",
      "description": "Dollar amount target for the investment goal."
    },
    "customer_risk_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Customer risk score (1=conservative, 10=aggressive)."
    },
    "goal_equity_pct": {
      "type": "number",
      "description": "Percentage of goal portfolio allocated to equities."
    },
    "goal_bond_pct": {
      "type": "number",
      "description": "Percentage of goal portfolio allocated to bonds."
    },
    "goal_cash_pct": {
      "type": "number",
      "description": "Percentage of goal portfolio allocated to cash."
    },
    "household_accounts": {
      "type": "array",
      "description": "All accounts in household for asset location optimization.",
      "items": {
        "type": "object",
        "required": ["account_id", "account_tax_type", "holdings"],
        "properties": {
          "account_id": {"type": "string"},
          "account_tax_type": {
            "type": "string",
            "enum": ["taxable", "traditional_ira", "roth_ira", "401k"]
          },
          "holdings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["symbol", "asset_category", "allocation_pct"],
              "properties": {
                "symbol": {"type": "string"},
                "asset_category": {"type": "string"},
                "allocation_pct": {"type": "number"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "customer_risk_tolerance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Customer risk tolerance level (1=conservative, 5=aggressive)."
    },
    "customer_experience_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Customer trading experience level (1=novice, 5=expert)."
    },
    "pending_strategies": {
      "type": "array",
      "description": "Pending investment strategies awaiting approval.",
      "items": {
        "type": "object",
        "required": ["strategy", "symbol", "risk_level"],
        "properties": {
          "strategy": {"type": "string"},
          "symbol": {"type": "string"},
          "risk_level": {"type": "integer"},
          "complexity": {"type": "integer"}
        },
        "additionalProperties": false
      }
    },
    "turnover_ratio_annual": {
      "type": "number",
      "description": "Annualized portfolio turnover ratio."
    },
    "cost_equity_ratio_annual": {
      "type": "number",
      "description": "Annual trading costs as a ratio of account equity."
    },
    "drip_enabled_symbols": {
      "type": "array",
      "description": "Symbols with dividend reinvestment (DRIP) enabled.",
      "items": {"type": "string"}
    },
    "direct_index_config": {
      "type": "object",
      "description": "Direct indexing configuration for stock-level TLH.",
      "properties": {
        "benchmark_index": {"type": "string"},
        "minimum_account_size": {"type": "number"},
        "individual_positions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["symbol", "weight_pct", "unrealized_pnl"],
            "properties": {
              "symbol": {"type": "string"},
              "weight_pct": {"type": "number"},
              "unrealized_pnl": {"type": "number"}
            },
            "additionalProperties": false
          }
        },
        "tracking_error_pct": {"type": "number"},
        "etf_holdings": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "copy_trading_config": {
      "type": "object",
      "description": "Copy trading configuration.",
      "properties": {
        "leader_username": {"type": "string"},
        "leader_risk_level": {"type": "integer", "minimum": 1, "maximum": 10},
        "copy_allocation_usd": {"type": "number"},
        "leader_portfolio_size": {"type": "number"},
        "leader_uses_margin": {"type": "boolean"},
        "leader_uses_options": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "margin_loan": {
      "type": "object",
      "description": "Securities-based lending / margin loan configuration.",
      "properties": {
        "loan_balance": {"type": "number"},
        "collateral_value": {"type": "number"},
        "maintenance_ltv_pct": {"type": "number"},
        "interest_rate_annual": {"type": "number"},
        "loan_purpose": {
          "type": "string",
          "enum": ["general", "securities_purchase", "real_estate", "other"]
        },
        "largest_collateral_position_pct": {"type": "number"}
      },
      "additionalProperties": false
    },
    "rmd_config": {
      "type": "object",
      "description": "Required Minimum Distribution and income portfolio configuration.",
      "properties": {
        "rmd_required": {"type": "boolean"},
        "prior_year_end_balance": {"type": "number"},
        "rmd_amount_scheduled": {"type": "number"},
        "rmd_amount_taken_ytd": {"type": "number"},
        "withdrawal_rate_pct": {"type": "number"},
        "income_equity_pct": {"type": "number"}
      },
      "additionalProperties": false
    },
    "event_contract_config": {
      "type": "object",
      "description": "Event contracts / prediction markets configuration.",
      "properties": {
        "positions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event_id", "direction", "contracts", "price_per_contract"],
            "properties": {
              "event_id": {"type": "string"},
              "direction": {"type": "string", "enum": ["yes", "no"]},
              "contracts": {"type": "integer"},
              "price_per_contract": {"type": "number"},
              "event_category": {"type": "string"},
              "expiration_date": {"type": "string", "format": "date"}
            },
            "additionalProperties": false
          }
        },
        "platform_position_limit_usd": {"type": "number"},
        "total_exposure_usd": {"type": "number"},
        "collateral_available": {"type": "number"}
      },
      "additionalProperties": false
    },
    "cash_management_config": {
      "type": "object",
      "description": "Cash management and sweep program configuration.",
      "properties": {
        "sweep_type": {
          "type": "string",
          "enum": ["bank_deposit", "money_market"]
        },
        "sweep_banks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["bank_name", "deposit_amount"],
            "properties": {
              "bank_name": {"type": "string"},
              "deposit_amount": {"type": "number"}
            },
            "additionalProperties": false
          }
        },
        "external_deposits_same_banks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["bank_name", "amount"],
            "properties": {
              "bank_name": {"type": "string"},
              "amount": {"type": "number"}
            },
            "additionalProperties": false
          }
        },
        "idle_cash_exempt": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "custodial_config": {
      "type": "object",
      "description": "Custodial account (UTMA/UGMA) configuration.",
      "properties": {
        "is_custodial": {"type": "boolean"},
        "minor_age": {"type": "integer"},
        "state_age_of_majority": {"type": "integer"},
        "unearned_income_ytd": {"type": "number"},
        "has_options": {"type": "boolean"},
        "has_margin": {"type": "boolean"},
        "has_futures": {"type": "boolean"},
        "has_short_positions": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "ai_supervision_config": {
      "type": "object",
      "description": "AI agent supervision and compliance configuration.",
      "properties": {
        "is_ai_generated": {"type": "boolean"},
        "has_risk_disclaimer": {"type": "boolean"},
        "contains_return_prediction": {"type": "boolean"},
        "suitability_check_completed": {"type": "boolean"},
        "interaction_logged": {"type": "boolean"},
        "model_version_tracked": {"type": "boolean"},
        "supervisory_review_enabled": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "alt_investment_config": {
      "type": "object",
      "description": "Alternative investments compliance configuration.",
      "properties": {
        "is_accredited_investor": {"type": "boolean"},
        "alt_positions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["symbol", "value_usd"],
            "properties": {
              "symbol": {"type": "string"},
              "value_usd": {"type": "number"},
              "expense_ratio_pct": {"type": "number"},
              "is_liquid_alt_etf": {"type": "boolean"},
              "has_lockup": {"type": "boolean"},
              "lockup_days_remaining": {"type": "integer"}
            },
            "additionalProperties": false
          }
        },
        "alt_allocation_cap_pct": {"type": "number"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
